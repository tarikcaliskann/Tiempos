# Spring Boot API. No trailing slash.
# Boş bırakın: tarayıcı aynı domain üzerinden /api kullanır (Vite proxy, Docker nginx, tiempos.site).
# VITE_API_BASE_URL=
# Frontend ve API farklı hostlardaysa (ör. Render static + ayrı API) build sırasında zorunlu:
# VITE_API_BASE_URL=https://tiempo-project.onrender.com

# Google OAuth (Web client) — "Google ile devam et" için zorunlu (Vite yeniden başlatın)
# Google Cloud Console -> Credentials -> OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins:
#   http://localhost:5173
#   https://www.tiempos.site
#   https://tiempo-project.onrender.com
# OAuth consent screen: Testing ise test kullanıcıları ekleyin veya Production'a alın
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
#
# Backend (Render / docker): aynı client id — ID token aud doğrulaması
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
