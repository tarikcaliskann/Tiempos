# =============================================================================
# Tiempos — kök .env şablonu
# Kullanım: cp .env.example .env  →  gerçek anahtarları / ID'leri doldurun
# Docker Compose (api + web), yerel ./mvnw ve mobil/run_local_chrome.sh bu dosyayı okuyabilir.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) Temel — yerel Spring (çoğu senaryo)
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=local

# JWT (zorunlu; en az ~32 karakter). Prod’da güçlü rastgele değer kullanın.
JWT_SECRET=local-dev-jwt-secret-at-least-32-chars-long

# --- Spring’i makinede çalıştırırken (docker compose api DEĞİL) Postgres :5433 ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/timebank
SPRING_DATASOURCE_USERNAME=timebank_user
SPRING_DATASOURCE_PASSWORD=1234

# Render / PaaS dinleyen port (Spring server.port)
PORT=8080

# -----------------------------------------------------------------------------
# 2) Google OAuth (Web + backend aynı “Web application” client ID)
# -----------------------------------------------------------------------------
# Google Cloud Console → OAuth 2.0 Web client → .apps.googleusercontent.com
# Yetkili JavaScript kökenleri: http://localhost:9339, http://localhost:5173, http://localhost:3000
# Boş bırakılırsa: yerelde giriş e‑posta/şifre çalışır; Google Web GSI başlatılamaz.
GOOGLE_CLIENT_ID=

# Vite (npm run dev / docker web build). Boşsa compose genelde GOOGLE_CLIENT_ID’den türetir.
VITE_GOOGLE_CLIENT_ID=

# Prod’da true: backend GOOGLE_CLIENT_ID zorunlu (application-prod ile uyumlu)
GOOGLE_REQUIRE_CLIENT_ID=false

# -----------------------------------------------------------------------------
# 3) CORS ve genel URL’ler
# -----------------------------------------------------------------------------
# Virgülle ayrılmış origin’ler. Yerel Flutter Web :9339 dahil örnek:
CORS_ALLOWED_ORIGINS=http://localhost:9339,http://127.0.0.1:9339,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,https://www.tiempos.site,https://tiempos.site

# false: Vite/LAN desenleri kapanır; Flutter :9339 CorsConfig’te yine açık kalır.
APP_CORS_BROWSER_DEV_PATTERNS=true

# Şifre sıfırlama / doğrulama linkleri, iletişim yanıtları için kök site
APP_PUBLIC_BASE_URL=http://localhost:3000

# İletişim formu hedefi
APP_CONTACT_INBOX=tiempos.site@gmail.com

# -----------------------------------------------------------------------------
# 4) Oturum çerezi (prod HTTPS’te genelde Secure + None)
# -----------------------------------------------------------------------------
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAME_SITE=Lax

# -----------------------------------------------------------------------------
# 5) Ödeme
# -----------------------------------------------------------------------------
PAYMENT_MODE=demo
PAYMENT_REDIRECT_URL_TEMPLATE=

# -----------------------------------------------------------------------------
# 6) Demo / SQL (yerel)
# -----------------------------------------------------------------------------
TIEMPOS_PRE_SESSION_DEMO=true
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# -----------------------------------------------------------------------------
# 7) E-posta — seçenek A: SMTP kapalı (sadece yerel API + giriş testi; doğrulama maili yok)
# -----------------------------------------------------------------------------
APP_MAIL_ENABLED=false
APP_MAIL_STRICT_ERRORS=false

# -----------------------------------------------------------------------------
# 8) E-posta — seçenek B: Brevo SMTP (APP_MAIL_ENABLED=true yapın; kullanıcı/şifre doldurun)
# -----------------------------------------------------------------------------
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
APP_MAIL_FROM=Tiempos <noreply@example.com>
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

# Kayıt doğrulama / şifre sıfırlama HTTPS yolu (Brevo Transactional API)
BREVO_API_KEY=

# -----------------------------------------------------------------------------
# 9) E-posta — seçenek C: Yerel Mailpit (docker compose up -d mailpit)
# Açmak için: APP_MAIL_ENABLED=true ve aşağıdaki üç satırı kullanın; üstteki Brevo host’unu yorum satırı yapın.
# -----------------------------------------------------------------------------
# SPRING_MAIL_HOST=localhost
# SPRING_MAIL_PORT=1025
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=false
# SPRING_MAIL_USERNAME=
# SPRING_MAIL_PASSWORD=

# -----------------------------------------------------------------------------
# 10) Oran sınırları (backend)
# -----------------------------------------------------------------------------
RATE_LIMIT_LOGIN_PER_MINUTE=20
RATE_LIMIT_CONTACT_PER_MINUTE=8
RATE_LIMIT_MESSAGES_PER_MINUTE=90

# -----------------------------------------------------------------------------
# 11) Frontend (Vite) — kök .env’den docker web build arg olarak da geçer
# -----------------------------------------------------------------------------
# Boş: aynı origin / nginx /api. Ayrı API host’u: sonunda /api OLMADAN kök URL
VITE_API_BASE_URL=
VITE_GA_MEASUREMENT_ID=

# Yerel Vite proxy hedefi (kök README; frontend/vite.config.ts)
DEV_API_PROXY=http://localhost:8080

# =============================================================================
# Prod (Render) için kısa kontrol listesi — değerleri yorum satırından çıkarıp doldurun
# =============================================================================
# SPRING_PROFILES_ACTIVE=prod
# SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:5432/DBNAME
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=
# GOOGLE_REQUIRE_CLIENT_ID=true
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# APP_PUBLIC_BASE_URL=https://www.tiempos.site
# CORS_ALLOWED_ORIGINS=https://www.tiempos.site,https://tiempos.site
# APP_AUTH_COOKIE_SECURE=true
# APP_AUTH_COOKIE_SAME_SITE=None
# TIEMPOS_PRE_SESSION_DEMO=false
# PAYMENT_MODE=redirect
# PAYMENT_REDIRECT_URL_TEMPLATE=https://...
# JPA_SHOW_SQL=false
# JPA_FORMAT_SQL=false
# APP_MAIL_ENABLED=true
# (Brevo SMTP + BREVO_API_KEY + APP_MAIL_FROM doğrulanmış gönderici)
