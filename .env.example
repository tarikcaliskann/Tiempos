# Yerel: cp .env.example .env
# Render (API): Environment’da aynı anahtarları doldurun; bu repo dosyası canlıda okunmaz.

# Yerel Spring profili (pre-session demo, SQL log, demo ödeme, geniş CORS)
SPRING_PROFILES_ACTIVE=local

# Backend JWT (yerel / prod; en az ~32 karakter önerilir)
JWT_SECRET=local-dev-jwt-secret-at-least-32-chars-long

# --- Canlı (Render API) — production-safe varsayılanlar application.properties içinde ---
# SPRING_PROFILES_ACTIVE=prod
# Flutter Web (localhost rastgele port) + Render API: CORS backend’de desenlerle
# açılır; yine de giriş/Google hata veriyorsa Render’da GOOGLE_CLIENT_ID dolu olmalı.
# GOOGLE_CLIENT_ID=...  (zorunlu — app.google.require-client-id=true)
# APP_AUTH_COOKIE_SECURE=true
# APP_AUTH_COOKIE_SAME_SITE=None
# TIEMPOS_PRE_SESSION_DEMO=false
# PAYMENT_MODE=redirect
# PAYMENT_REDIRECT_URL_TEMPLATE=https://your-psp.example/checkout?session={sessionId}&amount={amountTry}
# JPA_SHOW_SQL=false
# CORS_ALLOWED_ORIGINS=https://www.tiempos.site,https://tiempos.site
# Flutter web http://localhost:9339 ve 127.0.0.1:9339 CorsConfig’te her zaman açıktır.
# Vite/LAN desenleri: APP_CORS_BROWSER_DEV_PATTERNS=true (varsayılan). Sıkı API: false (9339 yine geçerli).
# (Boş bırakırsanız application.properties varsayılanı kullanılır.)

# =============================================================================
# Brevo SMTP
# Panel: https://app.brevo.com → Transactional → SMTP & API → SMTP
#   Login → SPRING_MAIL_USERNAME  |  SMTP key → SPRING_MAIL_PASSWORD (xsmtpsib-...; API key değil)
# Gönderici: Senders’da doğrulanmış adres → APP_MAIL_FROM ile uyumlu olmalı
# =============================================================================
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
APP_MAIL_FROM=Tiempos <noreply@tiempos.site>
APP_MAIL_ENABLED=true
APP_MAIL_STRICT_ERRORS=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

# Ön yüz ve e-posta linkleri için kök URL (ör. şifre sıfırlama, doğrulama)
APP_PUBLIC_BASE_URL=https://www.tiempos.site

# Brevo Transactional API (kayıt doğrulama, şifre sıfırlama, iletişim formu HTTPS yolu)
# Panel: Transactional → SMTP & API → API keys (xkeysib-...; SMTP xsmtpsib- ile karıştırma)
BREVO_API_KEY=

# Google Sign-In — yalnızca "Web application" OAuth istemcisi (.apps.googleusercontent.com)
# Android / iOS istemci kimliği burada ÇALIŞMAZ (GSI "origin not allowed" verir).
# Kök .env dosyasında doldurun; docker compose api + web build bu değerleri okur.
GOOGLE_CLIENT_ID=

# --- Vite (npm run dev); boşsa frontend /api/auth/google-config ile doldurur ---
# İpucu: Mümkünse GOOGLE_CLIENT_ID ile AYNI Web client ID string’ini verin (backend aud doğrulaması).
VITE_GOOGLE_CLIENT_ID=
#
# Tarayıcıda: [GSI_LOGGER]: The given origin is not allowed for the given client ID
# → Google Cloud Console → APIs & Services → Credentials → ilgili Web client →
#   "Authorized JavaScript origins" içine TAM kullandığınız kökü ekleyin (şema+host+port):
#   - http://localhost:5173   (Vite)
#   - http://127.0.0.1:5173   (localhost yerine 127.0.0.1 açtıysanız AYRI satır)
#   - http://localhost:3000   (docker compose web)
# Kaydettikten sonra 1–2 dk bekleyin; hâlâ 403 ise sayfayı sert yenileyin (Cmd+Shift+R).
#
# GET /api/skills veya POST /api/auth/social-login → 500 ise API loguna bakın:
#   docker compose logs api --tail=120
# (DB ayakta değilse, Flyway/şema hatası veya JWT_SECRET çok kısa da 500 üretebilir.)

# İletişim formu hedef gelen kutusu (backend’de kullanılıyorsa)
APP_CONTACT_INBOX=tiempos.site@gmail.com

# --- Yerel Mailpit (http://localhost:8025) ---
# SPRING_MAIL_HOST=mailpit
# SPRING_MAIL_PORT=1025
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=false
# SPRING_MAIL_USERNAME=
# SPRING_MAIL_PASSWORD=
# APP_MAIL_FROM=Tiempos <noreply@tiempos.local>

# --- Gmail (yalnızca yerel dene; prod’da Brevo önerilir) ---
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=you@gmail.com
# SPRING_MAIL_PASSWORD=16-char-app-password
# APP_MAIL_FROM=Tiempos <you@gmail.com>

# --- İsteğe bağlı: yerel `npm run dev` (kök .env; Vite proxy hedefi) ---
# Varsayılan http://localhost:8080. Tarayıcıda GET /api/skills → 500/502 veya boş gövde:
# önce `curl -sS http://localhost:8080/actuator/health` — API yoksa `docker compose up -d api db`.
# API başka porttaysa: DEV_API_PROXY=http://localhost:8082
# DEV_API_PROXY=http://localhost:8080
